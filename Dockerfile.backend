# Backend API — сборка из корня репозитория (Railway без Root Directory)
# Settings → Build → Builder: Dockerfile → Dockerfile Path: Dockerfile.backend

FROM golang:1.21-alpine AS builder

WORKDIR /src

COPY backend/go.mod backend/go.sum ./
RUN go mod download

COPY backend/ .
RUN go build -o /bin/backend .

FROM alpine:3.20

WORKDIR /app
RUN apk add --no-cache ca-certificates

COPY --from=builder /bin/backend /app/backend

EXPOSE 8080

CMD ["/app/backend"]
